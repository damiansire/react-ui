{
  "name": "react-ui",
  "private": true,
  "description": "Reusable React UI components, organized as an npm-workspaces monorepo. Each component is published to npm under its own name.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w react-dinamic-tables rollup-build-lib",
    "test": "npm run test --workspaces --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "vitest": "^1.6.0"
  }
}
